  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "server/src",
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["server/src/**/*.ts", "shared/**/*.ts"]
}
